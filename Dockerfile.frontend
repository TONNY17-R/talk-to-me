FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY frontend/package*.json ./

# Install dependencies
RUN npm ci

# Copy application code
COPY frontend/src ./src
COPY frontend/public ./public
COPY frontend/vite.config.js .
COPY frontend/.env.example .env

# Build application
RUN npm run build

# Expose port
EXPOSE 3000

# Run development server
CMD ["npm", "run", "dev"]
